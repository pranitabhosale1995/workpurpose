  <Paper elevation={2}>
      <Box  sx={{
       
        //maxHeight: 600,
       // overflow: "auto"
        height:550,
      width: "100%"
       
      }}> 
    <DataGrid
      //autoHeight
      rows={rows}
      columns={columns}
      loading={loading}
      rowCount={rowCount}
      paginationMode="server"
      paginationModel={paginationModel}
      onPaginationModelChange={handlePaginationChange}
      pageSizeOptions={[25, 50, 100]}
