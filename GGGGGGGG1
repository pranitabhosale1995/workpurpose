{showTable && (
  <>
    <Box
      sx={{
        display: "flex",
        justifyContent: "flex-end",
        mb: 1,
      }}
    >
      <Button
        variant="contained"
        color="success"
        size="small"
        onClick={handleExportButton}
        disabled={loading}
        sx={{
          textTransform: "none",
          minWidth: 100,
          height: 43,
        }}
      >
        Export
      </Button>
    </Box>

    <Paper elevation={2}>
      <Box
        sx={{
          width: "100%",
        }}
      >
        <DataGrid
          rows={rows}
          columns={columns}
          loading={loading}
          rowCount={rowCount}
          paginationMode="server"
          paginationModel={paginationModel}
          onPaginationModelChange={handlePaginationChange}
          pageSizeOptions={[25, 50, 100]}
          disableRowSelectionOnClick
        />
      </Box>
    </Paper>
  </>
)}
      </Box>
    </LocalizationProvider>
    </Paper>
  );
};

export default DateWiseSearch;
