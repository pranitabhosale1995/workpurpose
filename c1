import React, { useMemo, useState } from "react";
import {
  Box,
  Paper,
  Grid,
  Button,
  Typography,
  TextField,
  MenuItem,
} from "@mui/material";
import { DataGrid } from "@mui/x-data-grid";
import { DatePicker } from "@mui/x-date-pickers/DatePicker";
import dayjs from "dayjs";
import useApi from "../../hooks/useApi";

const DateWiseSearch = () => {
  const api = useApi();

  const [assetClassification, setAssetClassification] = useState("");
  const [fromDate, setFromDate] = useState(null);
  const [toDate, setToDate] = useState(null);

  const [rows, setRows] = useState([]);
  const [loading, setLoading] = useState(false);
  const [rowCount, setRowCount] = useState(0);

  const [errors, setErrors] = useState({});

  const [paginationModel, setPaginationModel] = useState({
    page: 0,
    pageSize: 25,
  });

  const assetClassificationOptions = [
    { value: "A", label: "A" },
    { value: "B", label: "B" },
    { value: "C", label: "C" },
    { value: "D", label: "D" },
    { value: "E", label: "E" },
  ];

  const validate = () => {
    const temp = {};

    if (!fromDate) {
      temp.fromDate = "From Date is required";
    }

    if (!toDate) {
      temp.toDate = "To Date is required";
    }

    setErrors(temp);

    return Object.keys(temp).length === 0;
  };

  const handleSearch = async (
    page = paginationModel.page,
    pageSize = paginationModel.pageSize
  ) => {
    if (!validate()) return;

    try {
      setLoading(true);

      const payload = {
        acClassification: assetClassification,
        fromDate: dayjs(fromDate).format("DD-MM-YYYY"),
        toDate: dayjs(toDate).format("DD-MM-YYYY"),
        pageNumber: page,
        pageSize,
      };

      const response = await api.post(
        "/api/voucher-transactions/search",
        payload
      );

      const data = response?.data?.data || {};

      setRows(
        (data.content || []).map((item) => ({
          id: item.transactionId,
          ...item,
        }))
      );

      setRowCount(data.totalElements || 0);
    } catch (error) {
      console.error("Date Wise Search Error", error);
    } finally {
      setLoading(false);
    }
  };

  const handlePaginationChange = (model) => {
    setPaginationModel(model);

    handleSearch(
      model.page,
      model.pageSize
    );
  };

  const handleReset = () => {
    setAssetClassification("");
    setFromDate(null);
    setToDate(null);
    setRows([]);
    setRowCount(0);
    setErrors({});
  };

  const columns = useMemo(
    () => [
      {
        field: "transactionId",
        headerName: "Transaction ID",
        flex: 1.2,
        minWidth: 170,
      },
      {
        field: "batchId",
        headerName: "Batch ID",
        flex: 1,
        minWidth: 140,
      },
      {
        field: "journalId",
        headerName: "Journal ID",
        flex: 1.2,
        minWidth: 160,
      },
      {
        field: "transactionDate",
        headerName: "Transaction Date",
        flex: 1,
        minWidth: 150,
      },
      {
        field: "postDate",
        headerName: "Posting Date",
        flex: 1.3,
        minWidth: 180,
      },
      {
        field: "cgl",
        headerName: "CGL",
        flex: 1,
        minWidth: 150,
      },
      {
        field: "currency",
        headerName: "Currency",
        flex: 0.8,
        minWidth: 100,
      },
      {
        field: "branchCode",
        headerName: "Branch Code",
        flex: 1,
        minWidth: 130,
      },
      {
        field: "action",
        headerName: "Action",
        minWidth: 120,
        sortable: false,
        filterable: false,
        renderCell: () => (
          <Button
            size="small"
            variant="outlined"
          >
            View
          </Button>
        ),
      },
    ],
    []
  );

  return (
    <Box sx={{ p: 3 }}>
      <Paper
        elevation={2}
        sx={{ p: 3, mb: 3 }}
      >
        <Typography
          variant="h6"
          fontWeight={600}
          mb={3}
        >
          Date Wise Search
        </Typography>

        <Grid
          container
          spacing={2}
          alignItems="center"
        >
          <Grid item xs={12} md={4}>
            <TextField
              select
              fullWidth
              label="Asset Classification"
              value={assetClassification}
              onChange={(e) =>
                setAssetClassification(
                  e.target.value
                )
              }
            >
              {assetClassificationOptions.map(
                (option) => (
                  <MenuItem
                    key={option.value}
                    value={option.value}
                  >
                    {option.label}
                  </MenuItem>
                )
              )}
            </TextField>
          </Grid>

          <Grid item xs={12} md={3}>
            <DatePicker
              label="From Date *"
              value={fromDate}
              onChange={setFromDate}
              format="DD-MM-YYYY"
              slotProps={{
                textField: {
                  fullWidth: true,
                  error:
                    !!errors.fromDate,
                  helperText:
                    errors.fromDate,
                },
              }}
            />
          </Grid>

          <Grid item xs={12} md={3}>
            <DatePicker
              label="To Date *"
              value={toDate}
              onChange={setToDate}
              format="DD-MM-YYYY"
              slotProps={{
                textField: {
                  fullWidth: true,
                  error: !!errors.toDate,
                  helperText:
                    errors.toDate,
                },
              }}
            />
          </Grid>

          <Grid item xs={12} md={2}>
            <Box
              display="flex"
              gap={1}
            >
              <Button
                fullWidth
                variant="contained"
                onClick={() =>
                  handleSearch()
                }
              >
                Search
              </Button>

              <Button
                fullWidth
                variant="outlined"
                onClick={handleReset}
              >
                Reset
              </Button>
            </Box>
          </Grid>
        </Grid>
      </Paper>

      <Paper elevation={2}>
        <DataGrid
          autoHeight
          rows={rows}
          columns={columns}
          loading={loading}
          rowCount={rowCount}
          paginationMode="server"
          paginationModel={
            paginationModel
          }
          onPaginationModelChange={
            handlePaginationChange
          }
          pageSizeOptions={[
            25,
            50,
            100,
          ]}
          disableRowSelectionOnClick
        />
      </Paper>
    </Box>
  );
};

export default DateWiseSearch;



import { LocalizationProvider } from "@mui/x-date-pickers/LocalizationProvider";
import { AdapterDayjs } from "@mui/x-date-pickers/AdapterDayjs";


return (
  <LocalizationProvider dateAdapter={AdapterDayjs}>
    <Box sx={{ p: 3 }}>
      {/* Tujha complete page code */}
    </Box>
  </LocalizationProvider>
);