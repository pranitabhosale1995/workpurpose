const fetchVoucherCategories = async () => {
  try {
    const response = await callApi(
      "/api/journals/voucher-categories",
      null,
      "GET"
    );

    console.log(
      "Voucher Categories Response =>",
      response
    );

    // API response handling
    const categories =
      response?.data ||
      response?.result ||
      [];

    // Convert string array to dropdown format
    const formattedCategories =
      categories.map((item) => ({
        label: item,
        value: item,
      }));

    setVoucherCategories(
      formattedCategories
    );

  } catch (error) {
    console.error(
      "Category API Error =>",
      error
    );

    setVoucherCategories([]);
  }
};