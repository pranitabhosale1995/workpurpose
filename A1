onChange={(e) => {
  const value = e.target.value;

  // First character space
  if (value.length > 0 && value[0] === " ") {
    setDeleteRemark(value);
    setRemarkError("Description should not start with a space.");
    return;
  }

  // Consecutive spaces
  if (value.includes("  ")) {
    setDeleteRemark(value);
    setRemarkError("Consecutive spaces are not allowed.");
    return;
  }

  // Max length
  if (value.length > 200) {
    setRemarkError("Maximum 200 characters allowed.");
    return;
  }

  setDeleteRemark(value);
  setRemarkError("");
}}