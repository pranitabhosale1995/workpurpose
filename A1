<TextField
  fullWidth
  multiline
  rows={5}
  label="Remark *"
  value={deleteRemark}
  onChange={(e) => {
    const value = e.target.value;

    if (value.startsWith(" ")) {
      setDeleteRemark(value);
      setRemarkError("Remark should not start with a space.");
      return;
    }

    if (value.includes("  ")) {
      setDeleteRemark(value);
      setRemarkError("Consecutive spaces are not allowed.");
      return;
    }

    if (value.length > 200) {
      setDeleteRemark(value);
      setRemarkError("Maximum 200 characters allowed.");
      return;
    }

    setDeleteRemark(value);
    setRemarkError("");
  }}
  inputProps={{ maxLength: 200 }}
  error={Boolean(remarkError)}
  helperText={
    remarkError
      ? remarkError
      : `All characters, numbers and special characters are allowed. (${deleteRemark.length}/200)`
  }
/>



onChange={(e) => {
  const value = e.target.value;

  // First character should not be space
  if (/^\s/.test(value)) {
    setRemarkError("Remark should not start with a space.");
    return; // state update करू नको
  }

  // Consecutive spaces
  if (/\s{2,}/.test(value)) {
    setRemarkError("Consecutive spaces are not allowed.");
    return;
  }

  if (value.length > 200) {
    setRemarkError("Maximum 200 characters allowed.");
    return;
  }

  setDeleteRemark(value);
  setRemarkError("");
}}