if (showCustomIssue) {
  const issue = customIssueInput.trim();

  if (!issue) {
    newErrors.customIssue =
      "Please enter issue";
  } else if (issue.length < 50) {
    newErrors.customIssue =
      "Minimum 50 characters required";
  } else if (
    !/^[A-Za-z0-9 ]+$/.test(issue)
  ) {
    newErrors.customIssue =
      "Special characters are not allowed";
  } else if (customIssues.length === 0) {
    newErrors.customIssue =
      "Please add this issue first";
  }
}



<TextField
  fullWidth
  label="Enter New Issue"
  value={customIssueInput}
  error={!!errors.customIssue}
  helperText={
    errors.customIssue
      ? errors.customIssue
      : `${customIssueInput.length}/50`
  }
  onChange={(e) => {
    setCustomIssueInput(e.target.value);

    setErrors((prev) => ({
      ...prev,
      customIssue: "",
    }));
  }}
/>