if (showCustomIssue) {
  const issue =
    customIssueInput.trim();

  if (!issue) {
    newErrors.customIssue =
      "Please enter issue";
  } else if (issue.length > 50) {
    newErrors.customIssue =
      "Maximum 50 characters allowed";
  }
}



onChange={(e) => {
  const value = e.target.value;

  if (!/^[A-Za-z0-9 ]*$/.test(value)) {
    setErrors((prev) => ({
      ...prev,
      customIssue:
        "Special characters are not allowed",
    }));
    return;
  }

  setCustomIssueInput(value);

  setErrors((prev) => ({
    ...prev,
    customIssue: "",
  }));
}}

inputProps={{
  maxLength: 50,
}}


if (
  selectedIssues.length === 0 &&
  customIssues.length === 0
) {
  if (showCustomIssue) {
    newErrors.customIssue =
      "Please add the issue first";
  } else {
    newErrors.issues =
      "Please select at least one issue";
  }
}