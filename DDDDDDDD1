import React, { useMemo, useState } from "react";
import {
  Box,
  Paper,
  Button,
  Typography,
  TextField,
  MenuItem,
  FormControl,
  InputLabel ,
  Select, 
  paperClasses
} from "@mui/material";
import { LocalizationProvider } from "@mui/x-date-pickers/LocalizationProvider";
import { AdapterDayjs } from "@mui/x-date-pickers/AdapterDayjs";

import { DataGrid } from "@mui/x-data-grid";
import { DatePicker } from "@mui/x-date-pickers/DatePicker";
import dayjs from "dayjs";
import useApi from "../../hooks/useApi";


const CGLSearch = () => {
  const { callApi } = useApi();
const [showTable, setShowTable] = useState(false);

 
  const [cgl, setcgl] = useState("");
  const [branchCode, setbranchCode] = useState("");   
  const [branchCodeError, setbranchCodeError] = useState("");
  const [transactionDate, settransactionDate] = useState(""); 

  
  const [rows, setRows] = useState([]);
  const [loading, setLoading] = useState(false);
  const [rowCount, setRowCount] = useState(0);

  const [errors, setErrors] = useState({});
  const [cglError, setcglError] = useState("");
  

  const [paginationModel, setPaginationModel] = useState({
    page: 0,
    pageSize: 25,
  });


   
//  const validate = () => {
//    const temp = {}; 
//    if (
//      transactionDate &&
//      dayjs(transactionDate).isAfter(
//        dayjs(),
//        "day"
//      )
//    ) {
//      temp.transactionDate =
//        "Future date is not allowed";
//    }

//    setErrors(temp);
 
//    return (
//      Object.keys(temp).length === 0
//    );
//  };
 

  const handleReset = () => { 
    setcgl("");
    setbranchCode(""); 
    settransactionDate(null);

  setRows([]);
  setRowCount(0);

  setPaginationModel({
    page: 0,
    pageSize: 25,
  });

  setErrors({});
  setShowTable(false);
};

 


 
//===========================================
 
const handleCLGChange = (e) => {
  const value = e.target.value; 
  // Max length
  if (value.length > 10) {
    setcglError("Maximum 10 numbers allowed");
    return;
  }  
  if (    
    !/^[0-9-]*$/.test(value)
  ) {
    setcglError(
      "Only numbers!"
    );
    return;
  }
 
  setcglError("");
  setcgl(value);
};

    


const handlebranchCodeChange = (e) => {
  const value = e.target.value; 
  // Max length
  if (value.length > 5) {
    setbranchCodeError("Maximum 5 numbers allowed");
    return;
  }  
  if (    
    !/^[0-9-]*$/.test(value)
  ) {
    setbranchCodeError(
      "Only numbers!"
    );
    return;
  }
 
  setbranchCodeError("");
  setbranchCode(value);
}; 

  const handleSearch = async (
    page = paginationModel.page,
    pageSize = paginationModel.pageSize
  ) => {  
    
    setLoading(true);

    try {
      const payload = {
     //   acClassification: assetClassification,
        cgl:cgl,
        branchCode:branchCode,
        transactionDate:transactionDate?dayjs(transactionDate).format("DD-MM-YYYY"):null,
        pageNumber: page,
        pageSize: pageSize,
      };

      console.log("Search Payload =>", payload);

      const response = await callApi(
        "/VE/voucher-transactions/search",
        payload,
        "POST"
      );

      console.log(
        "Search Response =>",
        response
      );

      const result = response?.data || {};

      console.log(
        "Content =>",
        result?.content
      );

      setRows(
        (result?.content || []).map(
          (item, index) => ({
            id: `${item.transactionId}-${index}`,
            transactionId:
              item.transactionId,
            batchId: item.batchId,
            journalId: item.journalId,
            transactionDate:
              item.transactionDate,
            postDate: item.postDate,
            cgl: item.cgl,
            currency:
              item.currency,
            branchCode:
              item.branchCode,
                 debitAmount:
              item.debitAmount,
              creditAmount:
              item.creditAmount,  
              narration:
              item.narration, 
          })
        )
      );

      setRowCount(
        result?.totalElements || 0
      );
      setShowTable(true);
    } catch (error) {
      console.error(
        "  Search  Error =>",
        error
      );
    } finally {
      setLoading(false);
    }
  };
  const handlePaginationChange = (model) => {
    setPaginationModel(model);

    handleSearch(
      model.page,
      model.pageSize
    );
  };



  const columns = useMemo(
    () => [
      
      {
        field: "batchId",
        headerName: "Batch ID",
        flex: 1,
        minWidth: 140,
      },
      {
        field: "journalId",
        headerName: "Journal ID",
        flex: 1,
        minWidth: 160,
      },
      {
        field: "transactionDate",
        headerName: "Transaction Date",
        flex: 1.2,
        minWidth: 150,
      },
       {
        field: "branchCode",
        headerName: "Branch Code",
        flex: 1,
        minWidth: 130,
      },
       {
        field: "currency",
        headerName: "Currency",
        flex: 0.8,
        minWidth: 100,
      },
       {
        field: "cgl",
        headerName: "CGL",
        flex: 1,
        minWidth: 150,
      },
      
      {
        field: "debitAmount",
        headerName: "Debit Amount",
        flex: 1.3,
        minWidth: 180,
      },
         {
        field: "creditAmount",
        headerName: "Credit Amount",
        flex: 1.3,
        minWidth: 180,
      },
         {
        field: "narration",
        headerName: "Narration",
        flex: 1.3,
        minWidth: 180,
      },
      
      
    ],
    []
  );

  return (
  <Paper
  elevation={2}
  sx={{
    p: 2,
    mb: 4,   
    //overflow: "auto",
    height:760  
  }}
>
          <LocalizationProvider
            dateAdapter={AdapterDayjs}
          > 
    <Box sx={{ p: 3 }}>
       
        <Typography variant="h5" mb={2}>
         CGLwise Search
        </Typography>     


  <Box
  sx={{
    display: "grid",
    gridTemplateColumns:
      "1fr 1fr 1fr auto auto",
    gap: 2,
    alignItems: "baseline",
    //alignItems: "center",
        mb:3,   
        
  }}
>
  <FormControl size="small"
    fullWidth
     >
    <InputLabel>
 
    </InputLabel>
    <TextField
               label="CGL"
                size="small"
                value={cgl}
                //sx={{ minWidth: 160 }}
             //   slotProps={{ htmlInput: { maxLength: 10 } }}
               // onChange={(e) => setcgl(e.target.value)}
                error={Boolean(cglError)}
                helperText={cglError || " "}
                onChange={handleCLGChange}
               //sx={{ minWidth: 160 }}

              />
       
  </FormControl>
 
  <FormControl size="small"
    fullWidth
     >
    <InputLabel>
     
    </InputLabel>
    <TextField
         label="Branch Code"
                size="small"
                value={branchCode}
                 error={Boolean(branchCodeError)}
                helperText={branchCodeError || " "}
                onChange={handlebranchCodeChange}
                //slotProps={{ htmlInput: { maxLength: 5 } }}
                //onChange={(e) => setbranchCode(e.target.value)}
              />
       
  </FormControl>

 


<DatePicker
    label="Date"
    // value={transactionDate}    
    // onChange={settransactionDate}
     value={transactionDate ? dayjs(transactionDate) : null} // Safely converts incoming state to Dayjs
     onChange={settransactionDate}
     maxDate={dayjs()}
     format="DD-MM-YYYY"     
     slotProps={{
      textField: {
          required: false,
        fullWidth: true,
          size: "small",
      },
    }}
  />
   
   
 

  <Button
  variant="contained"
  onClick={() =>
    handleSearch(
      paginationModel.page,
      paginationModel.pageSize
    )
  }
   sx={{
      minWidth: 90,
      height: 45,
      
    }}
>
  Search
</Button>

  <Button
    variant="outlined"
    onClick={handleReset}
    sx={{
      minWidth: 90,
      height: 45,
    
    }}
  >
    Reset
  </Button>
</Box>
 
      {showTable && (
  <Paper elevation={2}>
    <Box  sx={{
      
  // maxHeight: 500,
   // overflow: "auto"
   // height:600,
  width: "100%"
   
  }}> 
    <DataGrid
     // autoHeight
      rows={rows}
      columns={columns}
      loading={loading}
      rowCount={rowCount}
      paginationMode="server"
      paginationModel={paginationModel}
      onPaginationModelChange={handlePaginationChange}
      pageSizeOptions={[25, 50, 100]}
      disableRowSelectionOnClick
      
    />
    </Box>
  </Paper>
)}
      </Box>
     </LocalizationProvider>
     </Paper>
  );
};



export default CGLSearch;

