const handleChange = (e) => {
  const { name, value } = e.target;

  // Description मध्ये first character space allow नाही
  if (name === "description") {
    if (value.startsWith(" ")) {
      setErrors((prev) => ({
        ...prev,
        description: "First character cannot be a space.",
      }));
      return;
    } else {
      setErrors((prev) => ({
        ...prev,
        description: "",
      }));
    }
  }

  setFormData((prev) => ({
    ...prev,
    [name]: value,
  }));
};