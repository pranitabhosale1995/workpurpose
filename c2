
<Paper
  elevation={2}
  sx={{
    p: 3,
    borderRadius: 3,
  }}
>
  <Typography
    variant="h6"
    sx={{ mb: 3, fontWeight: 600 }}
  >
    Date Wise Search
  </Typography>

  <Box
    sx={{
      display: "grid",
      gridTemplateColumns:
        "1.2fr 1fr 1fr auto auto",
      gap: 2,
      alignItems: "center",
    }}
  >
    {/* Asset Classification */}

    <TextField
      select
      fullWidth
      label="Asset Classification"
      value={assetClassification}
      onChange={(e) =>
        setAssetClassification(e.target.value)
      }
    >
      {assetClassificationOptions.map(
        (option) => (
          <MenuItem
            key={option.value}
            value={option.value}
          >
            {option.label}
          </MenuItem>
        )
      )}
    </TextField>

    {/* From Date */}

    <DatePicker
      label="From Date *"
      value={fromDate}
      onChange={setFromDate}
      format="DD-MM-YYYY"
      slotProps={{
        textField: {
          fullWidth: true,
        },
      }}
    />

    {/* To Date */}

    <DatePicker
      label="To Date *"
      value={toDate}
      onChange={setToDate}
      format="DD-MM-YYYY"
      slotProps={{
        textField: {
          fullWidth: true,
        },
      }}
    />

    <Button
      variant="contained"
      onClick={handleSearch}
      sx={{
        minWidth: 90,
        height: 40,
      }}
    >
      Search
    </Button>

    <Button
      variant="outlined"
      onClick={handleReset}
      sx={{
        minWidth: 90,
        height: 40,
      }}
    >
      Reset
    </Button>
  </Box>
</Paper>