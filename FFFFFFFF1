<DatePicker
  label="Date"
  value={transactionDate}
  onChange={(newValue) => {
    settransactionDate(newValue);
    setErrors((prev) => ({
      ...prev,
      transactionDate: "",
    }));
  }}
  minDate={dayjs("2026-04-01")}
  maxDate={dayjs()}
  disableFuture
  format="DD-MM-YYYY"
  slotProps={{
    textField: {
      fullWidth: true,
      size: "small",
      error: !!errors.transactionDate,
      helperText:
        errors.transactionDate ||
        "Select Transaction Date",
      inputProps: {
        readOnly: true,
      },
    },
  }}
/>