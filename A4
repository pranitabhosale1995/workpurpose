const [voucherCategories, setVoucherCategories] =
  useState([
    "Payment",
    "Journal",
    "Adjustment",
    "Other",
  ]);

if (
  formData.voucherCategory === "Other" &&
  formData.otherCategory.trim()
) {
  const newCategory =
    formData.otherCategory.trim();

  const alreadyExists =
    voucherCategories.some(
      (item) =>
        item.toLowerCase() ===
        newCategory.toLowerCase()
    );

  if (!alreadyExists) {
    setVoucherCategories((prev) => [
      ...prev.filter(
        (item) => item !== "Other"
      ),
      newCategory,
      "Other",
    ]);
  }
}


const handleCreate = async () => {
  if (!validateForm()) {
    return;
  }

  setLoading(true);

  try {
    // Mock API Delay
    await new Promise((resolve) =>
      setTimeout(resolve, 1000)
    );

    // Add new category dynamically
    if (
      formData.voucherCategory === "Other" &&
      formData.otherCategory.trim()
    ) {
      const newCategory =
        formData.otherCategory.trim();

      const alreadyExists =
        voucherCategories.some(
          (item) =>
            item.toLowerCase() ===
            newCategory.toLowerCase()
        );

      if (!alreadyExists) {
        setVoucherCategories((prev) => [
          ...prev.filter(
            (item) => item !== "Other"
          ),
          newCategory,
          "Other",
        ]);
      }
    }

    // Payload
    const payload = {
      ...formData,

      vid: generateVID(),

      status: "ACTIVE",

      createdDate:
        new Date().toISOString(),
    };

    console.log(
      "Create Payload =>",
      payload
    );

    // Success Snackbar
    setSnackbar({
      open: true,
      message:
        "Voucher Request Created Successfully",
      severity: "success",
    });

    // Reset Form
    setFormData({
      voucherCategory: "",
      otherCategory: "",
      description: "",
      allowedRole: "",
      sdRequestNumber: "",
    });

  } catch (error) {
    console.error(error);

    setSnackbar({
      open: true,
      message: "Something went wrong",
      severity: "error",
    });

  } finally {
    setLoading(false);
  }
};


import ContentCopyIcon from "@mui/icons-material/ContentCopy";

import {
  Dialog,
  DialogTitle,
  DialogContent,
  DialogActions,
  IconButton,
} from "@mui/material";

import { useNavigate } from "react-router-dom";


const navigate = useNavigate();

const [openDialog, setOpenDialog] =
  useState(false);

const [createdVID, setCreatedVID] =
  useState("");



const handleCreate = async () => {
  if (!validateForm()) {
    return;
  }

  setLoading(true);

  try {
    await new Promise((resolve) =>
      setTimeout(resolve, 1000)
    );

    // Add new category dynamically
    if (
      formData.voucherCategory === "Other" &&
      formData.otherCategory.trim()
    ) {
      const newCategory =
        formData.otherCategory.trim();

      const alreadyExists =
        voucherCategories.some(
          (item) =>
            item.toLowerCase() ===
            newCategory.toLowerCase()
        );

      if (!alreadyExists) {
        setVoucherCategories((prev) => [
          ...prev.filter(
            (item) => item !== "Other"
          ),
          newCategory,
          "Other",
        ]);
      }
    }

    const generatedVID =
      generateVID();

    const payload = {
      ...formData,

      vid: generatedVID,

      status: "ACTIVE",

      createdDate:
        new Date().toISOString(),
    };

    console.log(
      "Create Payload =>",
      payload
    );

    // popup open
    setCreatedVID(generatedVID);

    setOpenDialog(true);

    // reset form
    setFormData({
      voucherCategory: "",
      otherCategory: "",
      description: "",
      allowedRole: "",
      sdRequestNumber: "",
    });

  } catch (error) {
    console.error(error);

    setSnackbar({
      open: true,
      message: "Something went wrong",
      severity: "error",
    });

  } finally {
    setLoading(false);
  }
};



<Dialog
  open={openDialog}
  onClose={() => setOpenDialog(false)}
  maxWidth="xs"
  fullWidth
>
  <DialogTitle>
    Voucher Request Created
  </DialogTitle>

  <DialogContent>
    <Typography mb={2}>
      Voucher ID
    </Typography>

    <Box
      sx={{
        display: "flex",
        alignItems: "center",
        justifyContent: "space-between",
        border: "1px solid #ccc",
        borderRadius: 2,
        px: 2,
        py: 1.5,
        background: "#f8f9fa",
      }}
    >
      <Typography
        fontWeight={700}
        color="primary"
      >
        {createdVID}
      </Typography>

      <IconButton
        onClick={() => {
