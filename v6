
const fetchDropdownData = async () => {
  try {

    const response = await callApi(
      "/JS/journals/search-vid",
      null,
      "GET"
    );

    const data = Array.isArray(response)
      ? response
      : response?.data || [];

    setAllData(data);

    const categories = [
      ...new Map(
        data.map((item) => [
          item.categoryId,
          {
            categoryId:
              item.categoryId,
            categoryName:
              item.categoryName,
          },
        ])
      ).values(),
    ];

    setCategoryOptions(
      categories
    );

    const statuses = [
      ...new Set(
        data.map(
          (item) => item.status
        )
      ),
    ];

    setStatusOptions(
      statuses
    );

  } catch (error) {

    console.error(
      "Dropdown Error =>",
      error
    );

  }
};



const fetchVouchers = async () => {
  setLoading(true);

  try {

    let url =
      "/JS/journals/search-vid";

    const queryParams = [];

    // Default table load
    if (
      !searchVID &&
      !searchStatus &&
      !searchDate &&
      !searchCategory
    ) {
      queryParams.push(
        "status=AVAILABLE"
      );
    }

    if (searchVID) {
      queryParams.push(
        `vid=${searchVID}`
      );
    }

    if (searchStatus) {
      queryParams.push(
        `status=${searchStatus}`
      );
    }

    if (searchDate) {
      queryParams.push(
        `date=${dayjs(
          searchDate
        ).format(
          "YYYY-MM-DD"
        )}`
      );
    }

    if (searchCategory) {
      queryParams.push(
        `categoryId=${searchCategory}`
      );
    }

    if (
      queryParams.length > 0
    ) {
      url +=
        "?" +
        queryParams.join("&");
    }

    console.log(
      "Table URL =>",
      url
    );

    const response =
      await callApi(
        url,
        null,
        "GET"
      );

    const data =
      Array.isArray(response)
        ? response
        : response?.data || [];

    setRows(data);

  } catch (error) {

    console.error(
      "Fetch Error =>",
      error
    );

    setSnackbar({
      open: true,
      message:
        "Failed to fetch vouchers",
      severity: "error",
    });

  } finally {

    setLoading(false);

  }
};


useEffect(() => {
  fetchDropdownData();
  fetchVouchers();
}, []);


