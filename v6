
const fetchVouchers = async () => {
  setLoading(true);

  try {
    let url = "/JS/journals/search-vid";

    const queryParams = [];

    // Default page load -> AVAILABLE only
    if (!searchVID && !searchStatus) {
      queryParams.push("status=AVAILABLE");
    }

    // User selected status
    if (searchStatus) {
      queryParams.push(
        `status=${searchStatus}`
      );
    }

    // VID Search
    if (searchVID) {
      queryParams.push(
        `vid=${searchVID}`
      );
    }

    // Date Search
    if (searchDate) {
      queryParams.push(
        `date=${dayjs(searchDate).format(
          "YYYY-MM-DD"
        )}`
      );
    }

    // Category Search
    if (searchCategory) {
      queryParams.push(
        `categoryId=${searchCategory}`
      );
    }

    if (queryParams.length > 0) {
      url +=
        "?" +
        queryParams.join("&");
    }

    console.log("API URL =>", url);

    const response = await callApi(
      url,
      null,
      "GET"
    );

    const data = Array.isArray(response)
      ? response
      : response?.data || [];

    setRows(data);

  } catch (error) {

    console.error(
      "Fetch Voucher Error =>",
      error
    );

    setSnackbar({
      open: true,
      message:
        "Failed to fetch vouchers",
      severity: "error",
    });

  } finally {

    setLoading(false);

  }
};