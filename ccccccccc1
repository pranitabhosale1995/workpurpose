import React, { useMemo, useState } from "react";
import {
  Box,
  Paper,
  Grid,
  Button,
  Typography,
  TextField,
  MenuItem,
  FormControl,
  InputLabel ,
  Select 
} from "@mui/material";
import { LocalizationProvider } from "@mui/x-date-pickers/LocalizationProvider";
import { AdapterDayjs } from "@mui/x-date-pickers/AdapterDayjs";

import { DataGrid } from "@mui/x-data-grid";
import { DatePicker } from "@mui/x-date-pickers/DatePicker";
import dayjs from "dayjs";
import useApi from "../../hooks/useApi";

const DateWiseSearch = () => {
  const { callApi } = useApi();
const [showTable, setShowTable] = useState(false);

  const [assetClassification, setAssetClassification] = useState("");
  const [fromDate, setFromDate] = useState(null);
  const [toDate, setToDate] = useState(null);

  const [rows, setRows] = useState([]);
  const [loading, setLoading] = useState(false);
  const [rowCount, setRowCount] = useState(0);

  const [errors, setErrors] = useState({});

  const [paginationModel, setPaginationModel] = useState({
    page: 0,
    pageSize: 25,
  });

  const assetClassificationOptions = [
    { value: "A", label: "Asset" },
    { value: "L", label: "Liability" },
    { value: "I", label: "Income" },
    { value: "E", label: "Expense" },
    { value: "M", label: "Memo A/c" },
  ];
 const validate = () => {
  const temp = {};

  if (!fromDate) {
    temp.fromDate = "From Date is required";
  }

  if (!toDate) {
    temp.toDate = "To Date is required";
  }

  if (
    fromDate &&
    dayjs(fromDate).isAfter(
      dayjs(),
      "day"
    )
  ) {
    temp.fromDate =
      "Future date is not allowed";
  }

  if (
    toDate &&
    dayjs(toDate).isAfter(
      dayjs(),
      "day"
    )
  ) {
    temp.toDate =
      "Future date is not allowed";
  }

  setErrors(temp);

  return (
    Object.keys(temp).length === 0
  );
};




  const handleReset = () => {
  setAssetClassification("");
  setFromDate(null);
  setToDate(null);

  setRows([]);
  setRowCount(0);

  setPaginationModel({
    page: 0,
    pageSize: 25,
  });

  setErrors({});

  setShowTable(false);
};


  const handleSearch = async (
    page = paginationModel.page,
    pageSize = paginationModel.pageSize
  ) => {
    if (!validate()) {
      return;
    }

    setLoading(true);

    try {
      const payload = {
        acClassification: assetClassification,
        fromDate: dayjs(fromDate).format("DD-MM-YYYY"),
        toDate: dayjs(toDate).format("DD-MM-YYYY"),
        pageNumber: page,
        pageSize: pageSize,
      };

      console.log("Search Payload =>", payload);

      const response = await callApi(
        "/VE/voucher-transactions/search",
        payload,
        "POST"
      );

      console.log(
        "Search Response =>",
        response
      );

      const result = response?.data || {};

      console.log(
        "Content =>",
        result?.content
      );

      setRows(
        (result?.content || []).map(
          (item, index) => ({
            id: `${item.transactionId}-${index}`,
             transactionId:
              item.transactionId,
            batchId: item.batchId,
            journalId: item.journalId,
            transactionDate:
              item.transactionDate,
            postDate: item.postDate,
            cgl: item.cgl,
            currency: item.currency,
            branchCode:
              item.branchCode,
             debitAmount:
              item.debitAmount,
              creditAmount:
              item.creditAmount,  
              narration:
              item.narration, 
          })
        )
      );

      setRowCount(
        result?.totalElements || 0
      );
      setShowTable(true);
    } catch (error) {
      console.error(
        "Date Wise Search Error =>",
        error
      );
    } finally {
      setLoading(false);
    }
  };
  const handlePaginationChange = (model) => {
    setPaginationModel(model);

    handleSearch(
      model.page,
      model.pageSize
    );
  };



  const columns = useMemo(
    () => [
       {
        field: "batchId",
        headerName: "Batch ID",
        flex: 1,
        minWidth: 140,
      },
      {
        field: "journalId",
        headerName: "Journal ID",
        flex: 1,
        minWidth: 160,
      },
      {
        field: "transactionDate",
        headerName: "Transaction Date",
        flex: 1.2,
        minWidth: 150,
      },
       {
        field: "branchCode",
        headerName: "Branch Code",
        flex: 1,
        minWidth: 130,
      },
       {
        field: "currency",
        headerName: "Currency",
        flex: 0.8,
        minWidth: 100,
      },
       {
        field: "cgl",
        headerName: "CGL",
        flex: 1,
        minWidth: 150,
      },
      
      {
        field: "debitAmount",
        headerName: "Debit Amount",
        flex: 1.3,
        minWidth: 180,
      },
         {
        field: "creditAmount",
        headerName: "Credit Amount",
        flex: 1.3,
        minWidth: 180,
      },
         {
        field: "narration",
        headerName: "Narration",
        flex: 1.3,
        minWidth: 180,
      },
      
    ],
    []
  );

  return (
    <Paper
      elevation={2}
      sx={{
        p: 2,
        mb: 2,
        //maxHeight: 600,
        overflow: "auto",
        height:750
        // marginBottom: '20px'
       
      }}
    > 

    <LocalizationProvider
      dateAdapter={AdapterDayjs}
    >
      <Box sx={{ p: 3 }}>

  <Typography
      variant="h6"
      sx={{ mb: 2, fontWeight: 500 }}
    >
      Date Wise Search
    </Typography>
   

  <Box
  sx={{
    display: "grid",
    gridTemplateColumns:
      "1.2fr 1fr 1fr auto auto",
    gap: 2,
    alignItems: "center",
    mb: 2
  }}
>
  <FormControl size="small"
    fullWidth
   
  >
    <InputLabel>
      Classification
    </InputLabel>

    <Select
      value={assetClassification}
      label="Classification"
      onChange={(e) =>
        setAssetClassification(
          e.target.value
        )
      }
    >
      {assetClassificationOptions.map(
        (option) => (
          <MenuItem
            key={option.value}
            value={option.value}
          >
            {option.label}
          </MenuItem>
        )
      )}
    </Select>
  </FormControl>

  <DatePicker
    label="From Date *"
    value={fromDate}
    maxDate={dayjs()}
    onChange={setFromDate}
    format="DD-MM-YYYY"
    slotProps={{
      textField: {
        fullWidth: true,
          size: "small",
      },
    }}
  />

  <DatePicker
    label="To Date *"
    value={toDate}
    maxDate={dayjs()}
    onChange={setToDate}
    format="DD-MM-YYYY"
    slotProps={{
      textField: {
        fullWidth: true,
          size: "small",
      },
    }}
  />

  <Button
  variant="contained"
  onClick={() =>
    handleSearch(
      paginationModel.page,
      paginationModel.pageSize
    )
  }
   sx={{
      minWidth: 90,
      height: 45,
      
    }}
>
  Search
</Button>

  <Button
    variant="outlined"
    onClick={handleReset}
    sx={{
      minWidth: 90,
      height: 45,
    }}
  >
    Reset
  </Button>
</Box>
 
      {showTable && (
  <Paper elevation={2}>
      <Box  sx={{
       
        //maxHeight: 600,
       // overflow: "auto"
        height:550,
      width: "100%"
       
      }}> 
    <DataGrid
      //autoHeight
      rows={rows}
      columns={columns}
      loading={loading}
      rowCount={rowCount}
      paginationMode="server"
      paginationModel={paginationModel}
      onPaginationModelChange={handlePaginationChange}
      pageSizeOptions={[25, 50, 100]}
      disableRowSelectionOnClick
    />
     </Box>
  </Paper>
)}
      </Box>
    </LocalizationProvider>
    </Paper>
  );
};

export default DateWiseSearch;
