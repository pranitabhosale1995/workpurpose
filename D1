const [vidError, setVidError] = useState("");

const validateVID = (value) => {
  if (!value) {
    setVidError("");
    return;
  }

  if (value.length > 50) {
    setVidError("Maximum 50 characters allowed");
    return;
  }

  if (!/^VID[0-9-]*$/.test(value)) {
    setVidError(
      "VID must start with VID and contain only numbers and hyphen"
    );
    return;
  }

  setVidError("");
};


