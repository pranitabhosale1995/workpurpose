<Typography
  variant="subtitle2"
  sx={{
    fontWeight: 700,
    mb: 1.5,
  }}
>
  Issues
</Typography>

{selectedIssues.length > 0 ? (
  <Box
    component="ul"
    sx={{
      pl: 3,
      m: 0,
    }}
  >
    {selectedIssues.map(
      (issue, index) => (
        <li key={index}>
          <Typography>
            {issue}
          </Typography>
        </li>
      )
    )}
  </Box>
) : (
  <Typography
    color="text.secondary"
  >
    No Issues Available
  </Typography>
)}