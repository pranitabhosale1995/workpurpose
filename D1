
const validateSearch = () => {
  if (!searchVID) {
    return true;
  }

  if (searchVID.length > 50) {
    setSnackbar({
      open: true,
      message: "Maximum 50 characters allowed",
      severity: "error",
    });
    return false;
  }

  if (!/^VID[0-9-]*$/.test(searchVID)) {
    setSnackbar({
      open: true,
      message:
        "VID must start with VID and contain only numbers and hyphen",
      severity: "error",
    });
    return false;
  }

  return true;
};


const handleSearch = () => {
  if (!validateSearch()) {
    return;
  }

  fetchVouchers();
};