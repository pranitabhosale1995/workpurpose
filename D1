<DialogContent sx={{ p: 3 }}>
  <Box
    sx={{
      display: "flex",
      flexDirection: "column",
      gap: 3,
      mt: 1,
    }}
  >
    {/* Description Section */}

    <Paper
      elevation={0}
      sx={{
        p: 2,
        border: "1px solid #E2E8F0",
        borderRadius: 2,
        bgcolor: "#F8FAFC",
      }}
    >
      <Typography
        variant="subtitle2"
        sx={{
          fontWeight: 600,
          color: "#475569",
          mb: 1,
        }}
      >
        Description
      </Typography>

      <Typography
        variant="body1"
        sx={{
          color: "#1E293B",
          whiteSpace: "pre-wrap",
          wordBreak: "break-word",
          lineHeight: 1.7,
        }}
      >
        {selectedDescription || "-"}
      </Typography>
    </Paper>

    {/* Issues Section */}

    <Paper
      elevation={0}
      sx={{
        p: 2,
        border: "1px solid #E2E8F0",
        borderRadius: 2,
      }}
    >
      <Typography
        variant="subtitle2"
        sx={{
          fontWeight: 600,
          color: "#475569",
          mb: 2,
        }}
      >
        Issue Categories
      </Typography>

      <Box
        sx={{
          display: "flex",
          flexWrap: "wrap",
          gap: 1,
        }}
      >
        {Array.isArray(selectedIssues) &&
        selectedIssues.length > 0 ? (
          selectedIssues.map(
            (issue, index) => (
              <Box
                key={index}
                sx={{
                  px: 1.5,
                  py: 0.8,
                  borderRadius: 5,
                  bgcolor: "#EEF2FF",
                  color: "#4338CA",
                  fontSize: "0.85rem",
                  fontWeight: 500,
                  border:
                    "1px solid #C7D2FE",
                }}
              >
                {typeof issue === "object"
                  ? issue.name ||
                    issue.issueName ||
                    issue.categoryName
                  : issue}
              </Box>
            )
          )
        ) : (
          <Typography
            variant="body2"
            color="text.secondary"
          >
            No Issue Categories Available
          </Typography>
        )}
      </Box>
    </Paper>
  </Box>
</DialogContent>