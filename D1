
const fileTypesRes = async () => {
  try {
    const response = await callApi(
      "/RS/ascii/file-types",
      null,
      "GET"
    );

    console.log("FULL RESPONSE =>", response);
    console.log("DATA =>", response?.data);

    setAsciiOptions(
      Array.isArray(response?.data)
        ? response.data
        : []
    );
  } catch (error) {
    console.error("File Types API Error =>", error);
    setAsciiOptions([]);
  }
};




{Array.isArray(asciiOptions) &&
  asciiOptions.map((item) => (
    <MenuItem key={item.id} value={item.id}>
      {item.asciiName}
    </MenuItem>
  ))
}