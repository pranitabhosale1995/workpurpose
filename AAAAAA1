onClick={() => {
  const newIssue =
    customIssueInput.trim();

  if (!newIssue) return;

  const alreadyExistsInMaster =
    issueList.some(
      (item) =>
        item.issueCategoryName
          ?.trim()
          .toLowerCase() ===
        newIssue.toLowerCase()
    );

  const alreadyExistsInCustom =
    customIssues.some(
      (item) =>
        item.trim().toLowerCase() ===
        newIssue.toLowerCase()
    );

  if (
    alreadyExistsInMaster ||
    alreadyExistsInCustom
  ) {
    setErrors((prev) => ({
      ...prev,
      customIssue:
        "Issue already exists",
    }));

    return;
  }

  setCustomIssues((prev) => [
    ...prev,
    newIssue,
  ]);

  setErrors((prev) => ({
    ...prev,
    issues: "",
    customIssue: "",
  }));

  setCustomIssueInput("");
}}

onChange={(e) => {
  setCustomIssueInput(
    e.target.value
  );

  setErrors((prev) => ({
    ...prev,
    customIssue: "",
  }));
}}



