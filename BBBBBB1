 
import React, { useEffect, useState } from "react";
import { useSelector } from "react-redux";
import {
  Alert,
  Box,
   Paper,
  Button,
  Card,
  Dialog,
  DialogActions,
  DialogContent,
  DialogTitle,
  FormControl,
  FormHelperText,
  IconButton,
  InputLabel,
  MenuItem,
  Select,
  Snackbar,
  TextField,
  Typography,
  Checkbox,
  Autocomplete,
  Chip
} from "@mui/material";
 
import ContentCopyIcon from "@mui/icons-material/ContentCopy";
import AddIcon from "@mui/icons-material/Add";
 
 
import { useNavigate } from "react-router-dom";
 
import useApi from "../../hooks/useApi";
 
import ViewVoucherRequestScreen from "./ViewVoucherRequestScreen";
 
const RequestVoucherScreen = () => {
const [customIssueError, setCustomIssueError] =
  useState("");
 
 const [showCustomIssue, setShowCustomIssue] =
  useState(false);
 
const [customIssueInput, setCustomIssueInput] =
  useState("");
 
const [customIssues, setCustomIssues] =
  useState([]);
 
const [issueList , setIssueList ] =
  useState([]);
const [selectedIssues  , setSelectedIssues  ] =
  useState([]);
 
const [issueOpen  , setIssueOpen  ] =
  useState(false);
 
 
  const { user } = useSelector((state) => state.auth);
 
  const navigate = useNavigate();
 
  const { callApi } = useApi();
 
  const [currentScreen, setCurrentScreen] =
    useState("request");
 
  const [voucherCategories, setVoucherCategories] =
    useState([]);
 
  const [roles, setRoles] =
    useState([]);
 
  const [loading, setLoading] =
    useState(false);
 
  const [roleLoading, setRoleLoading] =
    useState(false);
 
  const [openDialog, setOpenDialog] =
    useState(false);
 
  const [createdVID, setCreatedVID] =
    useState("");
 
  const [errors, setErrors] =
    useState({});
 
  const [snackbar, setSnackbar] =
    useState({
      open: false,
      message: "",
      severity: "success",
    });
 
  const [formData, setFormData] =
    useState({
      categoryId: "",
      otherCategory: "",
      description: "",
      roleId: "",
      sdRequestNumber: "",
    });
 
  useEffect(() => {
    fetchRoles();
    fetchVoucherCategories();
  }, []);
 
  const fetchVoucherCategories =
    async () => {
      try {
        const response = await callApi(    
          "/VE/voucher-transactions/voucher-categories",
          null,
          "GET"
        );    
 
        console.log(
          "Voucher Categories Response =>",
          response
        );
 
        const categories =
          Array.isArray(response)
            ? response
            : response?.data || [];
 
        setVoucherCategories(
          categories
        );
      } catch (error) {
        console.error(
          "Category API Error =>",
          error
        );
 
        setVoucherCategories([]);
      }
    };
 
  const fetchRoles = async () => {
    setRoleLoading(true);
 
    try {
      const response = await callApi(
        "/VE/voucher-transactions/allowed-roles?menuId=30",
        null,
        "GET"
      );
 
      console.log(
        "Allowed Roles Response =>",
        response
      );
 
      setRoles(
        Array.isArray(response.data)
          ? response.data
          : []
      );
    } catch (error) {
      console.error(
        "Failed to fetch roles",
        error
      );
 
      setSnackbar({
        open: true,
        message: "Failed to load roles",
        severity: "error",
      });
    } finally {
      setRoleLoading(false);
    }
  };
 
 
  const handleChange = (e) => {
    const { name, value } =
      e.target;
 
    if (
      name === "description" &&
      value.length > 500
    ) {
      return;
    }
 
    if (name === "otherCategory") {
      const regex =
        /^(?!.*\s{2,})[A-Za-z0-9 -]*$/;
 
      if (!regex.test(value)) {
         setErrors((prev)=> ({
        ...prev,
        otherCategory: "Special characheters and spaces not allowed",
         }));
         return;      
      }
 
      if(value.length >=20) {
         setErrors((prev)=> ({
        ...prev,
        otherCategory: "Maximum 20 characters allowed",
         }));
        return;
     }
   
    
    }

 
    if (name === "sdRequestNumber") {
      const regex =
        /^[0-9,]*$/;
 
      if (!regex.test(value)) {
        setErrors((prev)=> ({
        ...prev,
        sdRequestNumber: "Character, Special characheters and space not allowed",
         }));
         return; 
      }

       if(value.length >=21) {
         setErrors((prev)=> ({
        ...prev,
        sdRequestNumber: "Maximum 20 characters allowed",
         }));
        return;
     }
      
    }
 
    if (name === "categoryId") {
 
      const selectedCategory =
        voucherCategories.find(
          (item) => item.id == value
        );
      console.log(
        "Selected Category =>",
        selectedCategory
      );
 
      console.log(
        "Issues =>",
        selectedCategory?.issueCategories
      );
 
      setIssueList(
        selectedCategory?.issueCategories || []
      );
 
      setSelectedIssues([]);
     setCustomIssues([]);
setCustomIssueInput("");
setShowCustomIssue(false);
    }
 
 
    setFormData((prev) => ({
      ...prev,
      [name]: value,
    }));
 
    setErrors((prev) => ({
      ...prev,
      [name]: "",
    }));
  };
 

const validateForm = () => {
  let newErrors = {};

  if (!formData.categoryId) {
    newErrors.categoryId =
      "Voucher Category is required";
  }

  const selectedCategory =
    voucherCategories.find(
      (item) =>
        String(item.id) ===
        String(formData.categoryId)
    );

  console.log(
    "Selected Category =>",
    selectedCategory
  );

  console.log(
    "Form Category Id =>",
    formData.categoryId
  );

  console.log(
    "Entered Other Category =>",
    formData.otherCategory
  );

  // Other Category Validation
  if (
    selectedCategory?.categoryName
      ?.trim()
      .toLowerCase() === "other" &&
    !formData.otherCategory.trim()
  ) {
    newErrors.otherCategory =
      "Please enter other category";
  }

  if (
    selectedCategory?.categoryName
      ?.trim()
      .toLowerCase() === "other" &&
    formData.otherCategory.trim()
  ) {
    const enteredCategory =
      formData.otherCategory
        .trim()
        .toLowerCase();

    const categoryExists =
      voucherCategories.some(
        (item) => {
          const match =
            item.categoryName
              ?.trim()
              .toLowerCase() ===
            enteredCategory;

          console.log(
            "Comparing =>",
            item.categoryName,
            enteredCategory,
            match
          );

          return match;
        }
      );

    console.log(
      "Category Exists =>",
      categoryExists
    );

    if (categoryExists) {
      newErrors.otherCategory =
        "Category already exists";
    }
  }

  if (
    !formData.description.trim()
  ) {
    newErrors.description =
      "Description is required";
  }

  if (
    formData.description.length >
    500
  ) {
    newErrors.description =
      "Maximum 500 Characters Allowed";
  }

  if (!formData.roleId) {
    newErrors.roleId =
      "Allowed Role is required";
  }

  if (
    selectedIssues.length === 0 &&
    customIssues.filter(
      (item) => item?.trim()
    ).length === 0
  ) {
    newErrors.issues =
      "At least one issue is required";
  }

  if (
    selectedIssues.length === 0 &&
    customIssues.length === 0
  ) {
    if (showCustomIssue) {
      newErrors.customIssue =
        "Please add the issue first";
    } else {
      newErrors.issues =
        "Please select at least one issue";
    }
  }

  if (
    showCustomIssue &&
    customIssueInput.trim() &&
    customIssues.length === 0
  ) {
    newErrors.customIssue =
      "Please add this issue first";
  }

  console.log(
    "Validation Errors =>",
    newErrors
  );

  setErrors(newErrors);

  return (
    Object.keys(newErrors)
      .length === 0
  );
};
  const handleCreate =
    async () => {
      if (!validateForm()) {
        return;
      }
 
      setLoading(true);
 
      try {
        const selectedCategory =
          voucherCategories.find(
            (item) =>
              item.id ===
              formData.categoryId
          );
 
        const payload = {
          categoryId:
            formData.categoryId,
 
          customCategory:
            selectedCategory?.categoryName ===
              "Other"
              ? formData.otherCategory
              : "",
 
          description:
            formData.description,
 
          allowedRole:
            formData.roleId,
 
          sdReqNo:
            formData.sdRequestNumber,
 
          createdBy: user.userId,
 
          issueCategoryIds: selectedIssues.map(
            (item) => item.id
          ),
 
         
customIssueCategories:
  customIssues.filter(
    (item) => item?.trim()
  ),
 
 
        };
 
        console.log(
          "Create Payload =>",
          JSON.stringify(payload, null, 2)
        );
 
        const response =
          await callApi(
            "/VE/voucher-transactions/create-vid",
            payload,
            "POST"
          );
 
        console.log(
          "Create Response =>",
          response
        );
 
        await fetchVoucherCategories();
 
        const createdVid =
          response?.vid ||
          response?.data?.vid ||
          "";
 
        setCreatedVID(
          createdVid
        );
 
        setOpenDialog(true);
 
        setSnackbar({
          open: true,
          message:
            "Voucher Request Created Successfully",
          severity:
            "success",
        });
 
        setFormData({
          categoryId: "",
          otherCategory: "",
          description: "",
          roleId: "",
          sdRequestNumber: "",
 
        });
 
        setErrors({});
      } catch (error) {
        console.error(
          "Create Voucher Error =>",
          error
        );
 
        setSnackbar({
          open: true,
          message:
            "Failed To Create Voucher",
          severity: "error",
        });
      } finally {
        setLoading(false);
      }
    };
 
  const handleReset = () => {
    setFormData({
      categoryId: "",
      otherCategory: "",
      description: "",
      roleId: "",
      sdRequestNumber: "",
    });
setIssueList([]);
setSelectedIssues([]);
setCustomIssues([]);
setCustomIssueInput("");
setShowCustomIssue(false);
setIssueOpen(false);
    setErrors({});
  };
 
  if (currentScreen === "view") {
    return (
      <ViewVoucherRequestScreen />
    );
  }
 
  return (
    <Paper
  elevation={2}
  sx={{
    p: 2,
    mb: 4,  
   
    height:760  
  }}
>
    <Box p={4}>
           <Typography variant="h4" mb={6}>
           Request Voucher
              </Typography>  
      <Card
        elevation={3}
        sx={{
          maxWidth: "1100px",
          margin: "40px auto",
          padding: 4,
          borderRadius: 3,
        }}
      >
        
 
        <Box
          sx={{
            width: "100%",
            display: "flex",
            flexDirection:
              "column",
            gap: 3,
          }}
        >
          {/* Voucher Category + Other */}
          <Box
            sx={{
              display: "grid",
              gridTemplateColumns:
                voucherCategories.find(
                  (item) =>
                    item.id ===
                    formData.categoryId &&
                    item.categoryName ===
                    "Other"
                )
                  ? "1fr 1fr"
                  : "1fr",
 
              gap: 3,
 
              "@media (max-width:900px)":
              {
                gridTemplateColumns:
                  "1fr",
              },
            }}
          >
            {/* Voucher Category */}
            <FormControl
              fullWidth
              error={
                !!errors.categoryId
              }
            >
              <InputLabel>
                Voucher Category* 
              </InputLabel>
 
              <Select
                disabled={loading}
                name="categoryId"
                value={
                  formData.categoryId
                }
                onChange={
                  handleChange
                }
                label="Voucher Category"
                 MenuProps={{
                  PaperProps:{
                    sx:{
                      maxHeight:400,
                      overflow:"auto",
                    }
                  }
                }}
              >
                <MenuItem value="">
                  <em>
                    Select Category
                  </em>
                </MenuItem>
 
                {voucherCategories?.map(
                  (item) => (
                    <MenuItem
                      key={item.id}
                      value={item.id}
                    >
                      {
                        item.categoryName
                      }
                    </MenuItem>
                  )
                )}
              </Select>
 
              <FormHelperText>
                {
                  errors.categoryId
                }
              </FormHelperText>
            </FormControl>
 
            {/* Other Category */}
            {voucherCategories.find(
              (item) =>
                item.id ===
                formData.categoryId &&
                item.categoryName ===
                "Other"
            ) && (
                <TextField
                  disabled={loading}
                  fullWidth
                  label="Other Category *"
                  name="otherCategory"
                  value={
                    formData.otherCategory
                  }
                  onChange={
                    handleChange
                  }
                  error={
                    !!errors.otherCategory
                  }
                  inputProps={{
                    maxLength: 20,
                  }}
                  helperText={
                    errors.otherCategory
                      ? errors.otherCategory 
                      : `Only character,numbers, hyphen and single space allowed.  (${formData.otherCategory.length}/20)`
    
                  }
                />
              )}
          </Box>
 
         <Box
  sx={{
    display: "grid",
    gridTemplateColumns:
      showCustomIssue
        ? "0.90fr 0.90fr"
        : "1fr",
    gap: 3,
 
    "@media (max-width:900px)": {
      gridTemplateColumns: "1fr",
    },
  }}
>
  <Autocomplete
    multiple
    disableCloseOnSelect
 
     open={issueOpen}
 
onOpen={() => {
 
  if (!formData.categoryId) {
 
    setErrors((prev) => ({
      ...prev,
      issues:
        "Please select Voucher Category first",
    }));
 
    return;
  }
 
  setErrors((prev) => ({
    ...prev,
    issues: "",
  }));
 
  setIssueOpen(true);
}}
  onClose={() => setIssueOpen(false)}
 
   options={[
  ...issueList,
 
  ...(formData.categoryId
    ? [
        {
          id: "ADD_NEW",
          issueCategoryName:
            "+ Add Issue",
        },
      ]
    : []),
]}
    value={selectedIssues}
   
    onChange={(
      event,
      newValue
    ) => {
      const addIssueClicked =
        newValue.find(
          (item) =>
            item.id ===
            "ADD_NEW"
        );
 
     
if (addIssueClicked) {
  setShowCustomIssue(true);
  setIssueOpen(false);
 
  setSelectedIssues(
    newValue.filter(
      (item) => item.id !== "ADD_NEW"
    )
  );
 
  return;
}
      setSelectedIssues(
        newValue
      );
    }}
    getOptionLabel={(
      option
    ) =>
      option.issueCategoryName ||
      ""
    }
    renderOption={(
      props,
      option,
      { selected }
    ) => (
      <li {...props}>
        {option.id !==
          "ADD_NEW" && (
            <Checkbox
              checked={
                selected
              }
              size="small"
            />
          )}
 
        {
          option.issueCategoryName
        }
      </li>
    )}
    slotProps={{
      listbox:{
        sx:{
          maxHeight:300,
          overflowY:"auto"
        }
      }
    }}
   renderInput={(params) => (
  <TextField
    {...params}
    label="Search Issues*"
    placeholder="Search Issues"    
    error={!!errors.issues}
    helperText={errors.issues}
                 
           
  />
)}
  />
 
 
 {showCustomIssue && (
  <Box >
 
   
 
    <Box
      sx={{
        display: "flex",
        gap: 1,
       
      }}
    >
<TextField
  fullWidth
  label="Enter New Issue"
  value={customIssueInput}
  
 onChange={(e) => {
  setCustomIssueInput(
    e.target.value
  );

  setErrors((prev) => ({
    ...prev,
    customIssue: "",
  }));
}}
  error={!!errors.customIssue}
  inputProps={{
  maxLength: 100,
}}
  helperText={
    errors.customIssue
      ? errors.customIssue 
      : `${customIssueInput.length}/100`
  }
 
             
     
/>
 
      <Button size="small" sx={{
        minWidth:"80px",height:"50px",mt:"4px"
      }}
        variant="contained"
        startIcon={<AddIcon />}
       onClick={() => {
  const newIssue =
    customIssueInput.trim();

  if (!newIssue) return;

  const alreadyExistsInMaster =
    issueList.some(
      (item) =>
        item.issueCategoryName
          ?.trim()
          .toLowerCase() ===
        newIssue.toLowerCase()
    );

  const alreadyExistsInCustom =
    customIssues.some(
      (item) =>
        item.trim().toLowerCase() ===
        newIssue.toLowerCase()
    );

  if (
    alreadyExistsInMaster ||
    alreadyExistsInCustom
  ) {
    setErrors((prev) => ({
      ...prev,
      customIssue:
        "Issue already exists",
    }));

    return;
  }

  setCustomIssues((prev) => [
    ...prev,
    newIssue,
  ]);

  setErrors((prev) => ({
    ...prev,
    issues: "",
    customIssue: "",
  }));

  setCustomIssueInput("");
}}

      >
        Add
      </Button>
 
 
     
    </Box>
 
   
 
    {customIssues.length >
      0 && (
        <Box
          sx={{
            mt: 2,
            display: "flex",
            flexWrap: "wrap",
            gap: 1,
          }}
        >
          {customIssues.map(
            (
              issue,
              index
            ) => (
              <Chip
                key={index}
                label={issue}
                onDelete={() =>
                  setCustomIssues(
                    customIssues.filter(
                      (
                        _,
                        i
                      ) =>
                        i !==
                        index
                    )
                  )
                }
              />
            )
          )}
        </Box>
      )}
  </Box>
)}
</Box>
 
 
          {/* Allowed Role + SD */}
          <Box
            sx={{
              display: "grid",
              gridTemplateColumns:
                "1fr 1fr",
              gap: 3,
 
              "@media (max-width:900px)":
              {
                gridTemplateColumns:
                  "1fr",
              },
            }}
          >
            {/* Role */}
            <FormControl
              fullWidth
              error={
                !!errors.roleId
              }
            >
              <InputLabel>
                Allowed Role*
              </InputLabel>
              <Select
                disabled={loading || roleLoading}
                name="roleId"                
                value={formData.roleId}
                label="Allowed Role"
                onChange={handleChange}
                MenuProps={{
                  PaperProps:{
                    sx:{
                      maxHeight:250,
                      overflow:"auto",
                    }
                  }
                }}
                
              >
            
                <MenuItem value="">
                  <em>Select Role</em>
                </MenuItem>
 
                {roles?.map((role) => (
                  <MenuItem
                    key={role.roleId}
                    value={role.roleId}
                  >
                    {role.roleName}
                  </MenuItem>
                ))}
              </Select>
 
 
              <FormHelperText>
                {errors.roleId}
              </FormHelperText>
            </FormControl>
 
            {/* SD */}
            <TextField
              disabled={loading}
              fullWidth
              label="SD Request Number"
              name="sdRequestNumber"
              value={
                formData.sdRequestNumber
              }
              // onChange={
              //   handleChange
              // }
              // helperText="Only numbers and commas allowed"
               onChange={
                    handleChange
                  }
                  error={
                    !!errors.sdRequestNumber
                  }
                  inputProps={{
                    maxLength: 21,
                  }}
                  helperText={
                    errors.sdRequestNumber
                      ? errors.sdRequestNumber 
                      : `Only numbers and commas allowed.  (${formData.sdRequestNumber.length}/20)`
    
                  }
            />
          </Box>
 
          {/* Description */}
          <TextField
            disabled={loading}
            fullWidth
            multiline
            rows={5}
            label="Description*"
            name="description"
            value={
              formData.description
            }
            onChange={
              handleChange
            }
            error={
              !!errors.description
            }
            inputProps={{
              maxLength: 500,
            }}
            helperText={
              errors.description
                ? errors.description
                : `All characters, numbers, special characters and spaces are allowed.(${formData.description.length}/500)`
            }
          />

          
    
 
          {/* Buttons */}
          <Box
            sx={{
              display: "flex",
              justifyContent:
                "flex-end",
              gap: 2,
            }}
          >
            <Button
              variant="outlined"
              onClick={
                handleReset
              }
              disabled={loading}
              sx={{
                minWidth:
                  "120px",
                textTransform:
                  "none",
                borderRadius:
                  "8px",
              }}
            >
              Reset
            </Button>
 
            <Button
              variant="contained"
              onClick={
                handleCreate
              }
              disabled={loading}
              sx={{
                minWidth:
                  "120px",
                textTransform:
                  "none",
                borderRadius:
                  "8px",
              }}
            >
              {loading
                ? "Creating..."
                : "Create"}
            </Button>
          </Box>
        </Box>
      </Card>
 
      {/* Success Dialog */}
      <Dialog
        open={openDialog}
        onClose={() =>
          setOpenDialog(false)
        }
        maxWidth="xs"
        fullWidth
      >
        <DialogTitle>
          Voucher Request Created
        </DialogTitle>
 
        <DialogContent>
          <Typography mb={2}>
            Voucher ID
          </Typography>
 
          <Box
            sx={{
              display: "flex",
              alignItems:
                "center",
              justifyContent:
                "space-between",
              border:
                "1px solid #ccc",
              borderRadius: 2,
              px: 2,
              py: 1.5,
              background:
                "#f8f9fa",
            }}
          >
            <Typography
              fontWeight={700}
              color="primary"
            >
              {createdVID}
            </Typography>
 
            <IconButton
              onClick={() => {
                navigator.clipboard.writeText(
                  createdVID
                );
 
                setSnackbar({
                  open: true,
                  message:
                    "Voucher ID copied",
                  severity:
                    "success",
                });
              }}
            >
              <ContentCopyIcon />
            </IconButton>
          </Box>
        </DialogContent>
 
        <DialogActions
          sx={{
            p: 3,
            pt: 1,
          }}
        >
          <Button
  variant="outlined"
  onClick={() => {
    handleReset();
    setOpenDialog(false);
  }}
>
  Create New Voucher
</Button>
 
          <Button
            variant="contained"
            onClick={() => {
              setOpenDialog(
                false
              );
 
              setCurrentScreen(
                "view"
              );
            }}
          >
            View Requests
          </Button>
        </DialogActions>
      </Dialog>
 
      {/* Snackbar */}
      <Snackbar
        open={snackbar.open}
        autoHideDuration={
          3000
        }
        onClose={() =>
          setSnackbar(
            (prev) => ({
              ...prev,
              open: false,
            })
          )
        }
        anchorOrigin={{
          vertical: "top",
          horizontal:
            "right",
        }}
      >
        <Alert
          severity={
            snackbar.severity
          }
          variant="filled"
        >
          {snackbar.message}
        </Alert>
      </Snackbar>
    </Box>
    </Paper>
  );
};
 
export default RequestVoucherScreen;
 
