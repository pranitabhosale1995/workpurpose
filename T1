import { waitFor } from "@testing-library/react";

const mockCallApi = vi.fn();

vi.mock("../../hooks/useApi", () => ({
  default: () => ({
    callApi: mockCallApi,
  }),
}));


describe("RequestVoucherScreen - API And Dialog Tests", () => {

  it("should call APIs on component load", async () => {
    mockCallApi.mockResolvedValue([]);

    renderComponent();

    await waitFor(() => {
      expect(mockCallApi)
        .toHaveBeenCalled();
    });
  });

  it("should show success dialog after create api success", async () => {
    mockCallApi
      .mockResolvedValueOnce([])
      .mockResolvedValueOnce({
        data: [],
      })
      .mockResolvedValueOnce({
        vid: "VID12345",
      });

    renderComponent();

    fireEvent.change(
      screen.getByLabelText(
        /description/i
      ),
      {
        target: {
          value:
            "Test Description",
        },
      }
    );

    fireEvent.click(
      screen.getByRole(
        "button",
        {
          name: /create/i,
        }
      )
    );

    await waitFor(() => {
      expect(
        mockCallApi
      ).toHaveBeenCalled();
    });
  });

  it("should show error snackbar when api fails", async () => {
    mockCallApi.mockRejectedValue(
      new Error("API Error")
    );

    renderComponent();

    await waitFor(() => {
      expect(
        mockCallApi
      ).toHaveBeenCalled();
    });
  });

});




describe("RequestVoucherScreen - Advanced UI Tests", () => {

  it("should keep create button visible", () => {
    renderComponent();

    expect(
      screen.getByRole("button", {
        name: /create/i,
