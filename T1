
describe("RequestVoucherScreen - Validation Tests", () => {
  it("should show validation errors when create clicked without data", async () => {
    renderComponent();

    fireEvent.click(
      screen.getByRole("button", {
        name: /create/i,
      })
    );

    expect(
      await screen.findByText(
        /voucher category is required/i
      )
    ).toBeInTheDocument();

    expect(
      await screen.findByText(
        /description is required/i
      )
    ).toBeInTheDocument();

    expect(
      await screen.findByText(
        /allowed role is required/i
      )
    ).toBeInTheDocument();
  });

  it("should validate voucher category", async () => {
    renderComponent();

    fireEvent.click(
      screen.getByRole("button", {
        name: /create/i,
      })
    );

    expect(
      await screen.findByText(
        /voucher category is required/i
      )
    ).toBeInTheDocument();
  });

  it("should validate description field", async () => {
    renderComponent();

    fireEvent.click(
      screen.getByRole("button", {
        name: /create/i,
      })
    );

    expect(
      await screen.findByText(
        /description is required/i
      )
    ).toBeInTheDocument();
  });

  it("should validate allowed role", async () => {
    renderComponent();

    fireEvent.click(
      screen.getByRole("button", {
        name: /create/i,
      })
    );

    expect(
      await screen.findByText(
        /allowed role is required/i
      )
    ).toBeInTheDocument();
  });

  it("should clear description when reset clicked", () => {
    renderComponent();

    const description =
      screen.getByLabelText(
        /description/i
      );

    fireEvent.change(
      description,
      {
        target: {
          value:
            "Test Description",
        },
      }
    );

    fireEvent.click(
      screen.getByRole(
        "button",
        {
          name: /reset/i,
        }
      )
    );

    expect(
      description.value
    ).toBe("");
  });

  it("should allow numeric sd request number", () => {
    renderComponent();

    const input =
      screen.getByLabelText(
        /sd request number/i
      );

    fireEvent.change(
      input,
      {
        target: {
          value: "12345",
        },
      }
    );

    expect(
      input.value
    ).toBe("12345");
  });
});


import {
  render,
  screen,
  fireEvent,
} from "@testing-library/react";